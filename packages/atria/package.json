{
  "name": "atria",
  "version": "0.0.13",
  "description": "Unscoped atria CLI wrapper package",
  "keywords": [
    "atria",
    "cms",
    "cli",
    "tooling",
    "unscoped"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "atria": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@atria/cli": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atria-io/atria.git",
    "directory": "packages/atria"
  }
}
