{
  "name": "@atria/cli",
  "version": "0.0.46",
  "description": "CLI for atria project bootstrap and development",
  "keywords": [
    "atria",
    "cms",
    "cli",
    "developer-tools",
    "scaffold",
    "dev-server"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/runCli.js",
  "types": "dist/runCli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/runCli.d.ts",
      "default": "./dist/runCli.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@atria/admin": "workspace:*",
    "@atria/server": "workspace:*",
    "@atria/shared": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atria-io/atria.git",
    "directory": "packages/cli"
  }
}
